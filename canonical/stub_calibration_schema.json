{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/stub_calibration_schema.json",
  "title": "Stub Capacity Calibration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "timestamp",
    "config",
    "results",
    "theoretical_max_rps"
  ],
  "properties": {
    "type": {
      "const": "stub_capacity_calibration"
    },
    "timestamp": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stub_url",
        "stub_workers",
        "delay_ms",
        "requests_per_worker"
      ],
      "properties": {
        "stub_url": {
          "type": "string"
        },
        "stub_workers": {
          "type": "integer",
          "minimum": 1
        },
        "delay_ms": {
          "type": "integer",
          "minimum": 0
        },
        "requests_per_worker": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "concurrency",
          "total_requests",
          "successful",
          "errors",
          "throughput_rps",
          "wall_time_s",
          "latency_ms"
        ],
        "properties": {
          "concurrency": {
            "type": "integer",
            "minimum": 1
          },
          "total_requests": {
            "type": "integer",
            "minimum": 1
          },
          "successful": {
            "type": "integer",
            "minimum": 0
          },
          "errors": {
            "type": "integer",
            "minimum": 0
          },
          "throughput_rps": {
            "type": "number",
            "minimum": 0
          },
          "wall_time_s": {
            "type": "number",
            "minimum": 0
          },
          "latency_ms": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "min",
              "mean",
              "median",
              "p95",
              "p99",
              "max"
            ],
            "properties": {
              "min": {
                "type": "number"
              },
              "mean": {
                "type": "number"
              },
              "median": {
                "type": "number"
              },
              "p95": {
                "type": "number"
              },
              "p99": {
                "type": "number"
              },
              "max": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "theoretical_max_rps": {
      "type": "number",
      "minimum": 0
    }
  }
}
